# OpenClaw runtime environment variables
# Copy to .env.local for local development, register in Vercel for deployments.
# Do NOT commit real values.

# Vercel AI Gateway — auto-injected when AI Gateway is enabled on the project.
# Override locally for development.
AI_GATEWAY_API_KEY=

# Default LLM model. Always provider/model format. Example: anthropic/claude-haiku-4-5
DEFAULT_MODEL=anthropic/claude-haiku-4-5

# NestJS backend base URL (for memory snapshot, notifications, log).
# Local dev: http://localhost:3000
# Preview/prod: https://aim-backend-...vercel.app
BACKEND_BASE_URL=http://localhost:3000

# Shared bearer token between OpenClaw and NestJS backend. Same value on both sides.
# Generate with: openssl rand -base64 32 | tr '+/' '-_' | tr -d '='
BACKEND_SERVICE_TOKEN=

# Vercel Cron secret. Auto-injected by Vercel when set on the project.
# Local dev: any value, used by /api/tick handler check.
CRON_SECRET=
