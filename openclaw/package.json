{
  "name": "openclaw",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev -p 3001",
    "build": "next build",
    "start": "next start -p 3001",
    "typecheck": "tsc --noEmit",
    "vercel:link": "vercel link --yes",
    "vercel:env:pull": "vercel env pull .env.local",
    "vercel:build:preview": "vercel pull --yes --environment=preview && vercel build",
    "vercel:build:prod": "vercel pull --yes --environment=production && vercel build --prod",
    "vercel:deploy:preview": "pnpm vercel:build:preview && vercel deploy --prebuilt",
    "vercel:deploy:prod": "pnpm vercel:build:prod && vercel deploy --prebuilt --prod"
  },
  "dependencies": {
    "@ai-sdk/gateway": "^3.0.104",
    "@ai-sdk/google": "^3.0.64",
    "ai": "^6.0.168",
    "next": "16.2.4",
    "p-limit": "^7.3.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "typescript": "^5"
  }
}
