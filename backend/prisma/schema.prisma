// Prisma schema for MyClaw backend (P0 storage foundation)
// Plan reference: docs/plan/04-requirements.md, docs/plan/06-decision-log.md
// Spec: .omc/specs/deep-interview-be01-storage-foundation.md

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  profile       Profile?
  agents        Agent[]
  memory        MemoryDocument[]
  notifications Notification[]
}

model Profile {
  userId    String   @id
  nickname  String
  purpose   String?
  techLevel String? // 'low' | 'medium' | 'high' (추론값)
  joinedAt  DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Agent {
  id        String   @id @default(uuid())
  userId    String
  name      String
  status    String   @default("active") // 'active' | 'archived'
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model MemoryDocument {
  // llm-wiki 패턴: path가 폴더-경로 (예: "profile", "preferences", "agents/abc/SOUL")
  userId      String
  path        String
  body        String // 마크다운 + frontmatter 통째로
  frontmatter Json // 파싱된 frontmatter (조회 가속)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([userId, path])
  @@index([userId])
}

model Skill {
  id            String   @id // 예: "insane-search"
  name          String
  description   String
  triggers      String[] // 자연어 매칭용 키워드
  defaultParams Json?
  enabled       Boolean  @default(true)
  createdAt     DateTime @default(now())
}

model Notification {
  id        String   @id @default(uuid())
  userId    String
  agentId   String?
  kind      String   // 'alert' | 'message'
  body      String
  meta      Json?    // used_skills 등 추가 정보
  readAt    DateTime?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@index([userId])
}
