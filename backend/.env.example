# Vercel Postgres / Neon connection strings
# Pooled (for runtime): used by Prisma Client
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DB?sslmode=require&pgbouncer=true&connection_limit=1"
# Direct (for migrations): used by `prisma migrate`
DIRECT_URL="postgresql://USER:PASSWORD@HOST/DB?sslmode=require"

# App
PORT=3000
